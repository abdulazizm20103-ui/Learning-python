products = {}
while True:
  print("1-добавить 2-удалить 3-показать 4-сумма 5-выход")
  a = input("выбери от 1-5 ")
  if a == "1":
      n = input("название:")
      p = int(input("цена:"))
      q = int(input("количество:"))
      c = input("категория:")
      products[n] = {"price": p, "quantity": q, "category": c }

  elif a == "2":
    n = input("удалить: ")
    if n in products:
      del products[n]

      print("продукт удалён")

  elif a == "3":
    print(products)

  elif a == "4":
    print("обшая сумма =",  sum(i["price"] * i["quantity"] for i in products.values()))
  elif a == "5":
   break
